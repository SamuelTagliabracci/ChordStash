[Unit]
Description=ChordStash Chord Sheet Manager
After=network.target

[Service]
Type=simple
User=your-username
WorkingDirectory=/path/to/ChordStash
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
